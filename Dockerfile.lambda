FROM public.ecr.aws/lambda/nodejs:20 AS builder

WORKDIR /app
COPY package.json package-lock.json ./
# Use npm install (not ci) so it resolves Linux native deps
RUN npm install --ignore-scripts
COPY . .
RUN npm install lightningcss-linux-x64-gnu lightningcss-linux-x64-musl @tailwindcss/oxide-linux-x64-gnu --save-optional
RUN npm run build

FROM public.ecr.aws/lambda/nodejs:20

WORKDIR /app

# Copy Lambda Web Adapter binary (Rust extension, not npm)
COPY --from=public.ecr.aws/awsguru/aws-lambda-adapter:1.0.0 /lambda-adapter /opt/extensions/lambda-adapter

# Install production dependencies
COPY package.json package-lock.json ./
RUN npm ci --omit=dev

# Copy build artifacts
COPY --from=builder /app/.next ./.next
COPY --from=builder /app/public ./public
COPY --from=builder /app/next.config.ts ./next.config.ts
COPY --from=builder /app/postcss.config.mjs ./postcss.config.mjs

ENV PORT=3000
ENV AWS_LWA_PORT=3000
ENV NODE_ENV=production

CMD ["node", "/app/node_modules/.bin/next", "start", "-p", "3000"]
