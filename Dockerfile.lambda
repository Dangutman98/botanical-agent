FROM public.ecr.aws/docker/library/node:20-slim AS builder

WORKDIR /app
COPY package.json package-lock.json ./
RUN npm install --ignore-scripts
COPY . .
RUN npm install lightningcss-linux-x64-gnu lightningcss-linux-x64-musl @tailwindcss/oxide-linux-x64-gnu --save-optional
RUN npm run build

FROM public.ecr.aws/docker/library/node:20-slim

WORKDIR /app

# Copy Lambda Web Adapter
COPY --from=public.ecr.aws/awsguru/aws-lambda-adapter:1.0.0 /lambda-adapter /usr/local/bin/lambda-adapter

# Copy standalone server
COPY --from=builder /app/.next/standalone ./

# CRITICAL: Copy node_modules so the server has its dependencies
COPY --from=builder /app/node_modules ./node_modules

# Copy static assets
COPY --from=builder /app/.next/static ./.next/static
COPY --from=builder /app/public ./public

# Crucial: Bind to 0.0.0.0 so Lambda can reach it
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
ENV HOST=0.0.0.0
ENV AWS_LWA_PORT=3000
ENV NODE_ENV=production

ENTRYPOINT ["/usr/local/bin/lambda-adapter"]
CMD ["node", "server.js"]